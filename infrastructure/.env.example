# GRACE production environment.
# Copy to infrastructure/.env and fill in. NEVER commit .env (gitignored).

# REQUIRED — your Anthropic API key. Billing accrues to this account.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED — demo gate password. Share with the analysts who should have
# access. Pick a long random string; rotate it when no longer needed.
# If you leave this empty, ANYONE on the internet can use your deployment.
GRACE_DEMO_PASSWORD=

# REQUIRED — public DNS hostname pointing at this server's IP. Caddy
# uses this to auto-provision a Let's Encrypt TLS certificate.
# Free options: grace-demo.duckdns.org (DuckDNS), or a Cloudflare-managed
# subdomain. Must resolve to the VM's public IP BEFORE first start, or
# Let's Encrypt validation will fail.
GRACE_DOMAIN=grace-demo.example.org

# OPTIONAL — contact email for Let's Encrypt expiry / revocation notices.
GRACE_ACME_EMAIL=

# OPTIONAL — frontend defaults
GRACE_DEFAULT_LANGUAGE=en
GRACE_DEFAULT_THEME=light
